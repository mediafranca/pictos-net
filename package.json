{
  "name": "pictos.net",
  "private": true,
  "version": "2.1.2",
  "type": "module",
  "scripts": {
    "dev": "npm run copy-schemas && npm run optimize-thumbs && netlify dev",
    "build": "npm run copy-schemas && npm run optimize-thumbs && vite build",
    "preview": "npm run copy-schemas && vite preview",
    "generate-index": "node scripts/generate-libraries-index.cjs",
    "validate-i18n": "node scripts/validateTranslations.cjs",
