# Local development environment variables
# Copy to .env and fill in real values. Never commit .env — it is git-ignored.
# For Netlify deployments, copy to .env-netlify (also git-ignored) and run:
#   netlify env:import .env-netlify

# ── AI API Keys (required) ─────────────────────────────────────────────────────
# PICTOS_ANTHROPIC_KEY is used by api-claude.js instead of ANTHROPIC_API_KEY to
# avoid Netlify CLI v24 overriding it with a Netlify AI Gateway JWT at dev time.
PICTOS_ANTHROPIC_KEY=sk-ant-api03-...
# Keep ANTHROPIC_API_KEY as fallback (used if PICTOS_ANTHROPIC_KEY is absent).
ANTHROPIC_API_KEY=sk-ant-api03-...
RECRAFT_API_KEY=re-...

# ── Gemini API Keys (Phase 3 — required for Gemini image models) ──────────────
# GEMINI_LOCAL_API_KEY: used in local dev (netlify dev). No application restriction needed;
#   restrict by API type only (Generative Language API).
# GEMINI_PUBLIC_API_KEY: used in deployed environments (next.pictos.net, pictos.net).
#   Must also be restricted by API type only — NOT by HTTP referrer (breaks server-side calls).
GEMINI_PUBLIC_API_KEY=AIza...
GEMINI_LOCAL_API_KEY=AIza...

# ── GitHub token for pictogram sharing (optional) ─────────────────────────────
# Needs: repo:write on pictogram-collector
GITHUB_TOKEN=ghp_...

# ── Usage quota (optional, default: 100) ──────────────────────────────────────
# Maximum pictogram generations per user per calendar day (UTC).
# Charged calls: Recraft (phase 3) = 1 unit, Claude Sonnet (phase 5) = 1 unit.
# Claude Haiku (phases 1+2) = 0 units (free).
DAILY_LIMIT_PER_USER=50

# ── API Admin Key (optional) ──────────────────────────────────────────────────
# Permite acceder a los reportes de uso de manera remota mediante scripts.
# Definir en ambos lados: panel de Netlify y en tu script local.
ADMIN_API_KEY=tu-llave-super-secreta

