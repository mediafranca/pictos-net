-- allium: 3
-- visual-reasoning.allium

-- Scope: Generative pipeline from communicative intention to structured pictogram.
-- Includes: Phase 1 (COMPRENDER), Phase 2 (COMPONER), Phase 3 (PRODUCIR),
--   Phase 4 (VECTORIZAR, user-triggered), Phase 5 (ESTRUCTURAR),
--   artifact lifecycle, invalidation cascade, per-phase re-execution,
--   background execution pattern (timer, stop), and phase error handling.
-- Excludes:
--   - Generation model selection and library-level model config (generation-config.allium)
--   - Library backward-compatibility and migration (separate spec)
--   - Netlify function infrastructure, security, and quota (usage-enforcement.allium)
--   - SVG editor interactions (separate spec)
-- Dependencies: nlu-schema, mf-svg-schema, GlobalConfig, generation-config.allium

------------------------------------------------------------
-- Value Types
------------------------------------------------------------

value PhaseStatus {
  idle | running | completed | failed | outdated
}

value NLUData {
  -- Semantic analysis of the communicative intention.
  -- Schema enforced by nlu-schema via Claude tool use.
  utterance: String
  lang: String
  domain: String?
  frames: [Frame]
  visual_guidelines: VisualGuidelines
  nsm_explications: Map<String, String>
  pragmatics: Pragmatics
}

value VisualDOMNode {
  -- One semantic node in the pictogram's DOM.
  -- id must be unique and mf-svg-schema compliant.
  id: String
  concept: String
  label: String
  required: Boolean
  children: [VisualDOMNode]?
}

value VisualDOM {
  -- The target semantic structure proposed by Phase 2.
  -- This is the contract that Phase 5 maps against.
  nodes: [VisualDOMNode]
}

value ElementMark {
  -- One indexed element extracted from rawSvg for set-of-marks.
  index: Number
  boundingBox: BBox
  centroid: Point
}

value ElementMapping {
  -- Claude's assignment of one marked element to a DOM node.
  elementIndex: Number
  nodeId: String | "none"    -- must be a valid VisualDOMNode id or "none"
  confidence: Number         -- 0.0 to 1.0
  justification: String
}

------------------------------------------------------------
-- External Entities
------------------------------------------------------------

external GlobalConfig {
  -- User-level configuration forwarded to every pipeline phase.
  lang: String
  geoContext: String?
  annotatedContext: String?
  visualStylePrompt: String
  generationModel: GenerationModel    -- see generation-config.allium
}

------------------------------------------------------------
-- Entities
------------------------------------------------------------

entity VisualReasoning {
  -- A single pictogram generation in progress.
  -- One VisualReasoning instance per utterance being worked on.

  utterance: String

  -- Phase 1
  nluData: NLUData?
  phase1Status: PhaseStatus = idle

  -- Phase 2
  visualDom: VisualDOM?
  visualPrompt: String?         -- prompt text delivered to Phase 3
  phase2Status: PhaseStatus = idle

  -- Phase 3
  bitmap: String?               -- base64 PNG (800×800px); set by bitmap-producing models
  rawSvg: String?               -- native SVG; set by vector model (Phase 3) or VTrace (Phase 4)
  generationModel: GenerationModel?   -- model that produced Phase 3 output; frozen at completion
  phase3Status: PhaseStatus = idle

  -- Phase 4 (user-triggered; only available for bitmap-producing model rows)
  phase4Status: PhaseStatus = idle

  -- Phase 5
  pictograma: String?           -- mf-svg-schema structured SVG, single source of truth
  phase5Status: PhaseStatus = idle
}

------------------------------------------------------------
-- Config
------------------------------------------------------------

config {
  phase5_max_attempts: Number = 3
  phase5_confidence_threshold: Number = 0.7
}

------------------------------------------------------------
-- Rules
------------------------------------------------------------

-- === Invalidation cascade ===

rule InvalidateDownstream {
  when: a phase of a VisualReasoning transitions to completed

  ensures: every phase downstream of the completed phase
    transitions to outdated if it was previously completed or failed

  -- Downstream order for bitmap-producing models:
  --   phase1 → phase2 → phase3 → phase4 → phase5
  -- Downstream order for vector-direct models (recraftv4_1_vector):
  --   phase1 → phase2 → phase3 → phase5
  --   phase4 is not in the chain; it transitions to idle when phase3 completes
  --   with a rawSvg output (no bitmap to trace)
  -- Example: completing phase3 with a bitmap model marks phase4 and phase5 as outdated.
  -- Example: completing phase3 with a vector model resets phase4 to idle and
  --   marks phase5 as outdated.
  -- Example: completing phase4 marks only phase5 as outdated.
  -- Completing phase5 marks nothing (terminal phase).

  -- Artifact clearing on phase3 completion:
  --   bitmap-producing result: prior rawSvg (from Phase 4) and pictograma are cleared
  --   vector result: prior bitmap is set to nil; pictograma is cleared
  -- This ensures artifact fields are consistent with the new phase3 output type.
}

-- === Phase 1: COMPRENDER ===

rule Phase1_Comprender {
  when: phase 1 is triggered for a VisualReasoning

  requires: VisualReasoning.utterance is non-empty

  ensures: Claude Haiku called with tool use
    -- tool name: "analyze_utterance"
    -- tool input_schema: nlu-schema JSON Schema
    -- tool_choice: forced to "analyze_utterance"
    -- inputs forwarded: utterance, GlobalConfig (lang, geoContext, annotatedContext)
  ensures: on success:
    VisualReasoning.nluData = parsed NLUData from tool call arguments
    VisualReasoning.phase1Status = completed
  ensures: on tool-use failure (Claude does not invoke tool, or parse error):
    VisualReasoning.phase1Status = failed
}

rule Phase1_Failure {
  when: VisualReasoning.phase1Status transitions to failed

  ensures: full error detail logged to console (provider error, raw response)
  ensures: phase 1 indicator shown as failed in UI
  -- User manually re-triggers phase 1 to retry.
}

-- === Phase 2: COMPONER ===

rule Phase2_Componer {
  when: phase 2 is triggered for a VisualReasoning

  requires: VisualReasoning.phase1Status = completed
  requires: VisualReasoning.nluData is present

  ensures: Claude Haiku called with tool use
    -- tool name: "compose_pictogram"
    -- tool input_schema: { visualDom: VisualDOM, visualPrompt: String }
        where VisualDOM conforms to mf-svg-schema node structure
    -- tool_choice: forced to "compose_pictogram"
  ensures: on success:
    VisualReasoning.visualDom = parsed VisualDOM from tool arguments
    VisualReasoning.visualPrompt = visualPrompt string from tool arguments
    VisualReasoning.phase2Status = completed
  ensures: on tool-use failure:
    VisualReasoning.phase2Status = failed

  @invariant "single response delivers both artifacts"
    -- VisualDOM and visualPrompt are produced in one tool call response.
    -- They are not generated by separate Claude calls.

  @invariant "DOM validated before continuing"
    -- VisualDOM is validated against mf-svg-schema before phase2Status
    -- transitions to completed. Validation failure is treated as tool-use failure.
}

rule Phase2_Failure {
  when: VisualReasoning.phase2Status transitions to failed

  ensures: full error detail logged to console
  ensures: phase 2 indicator shown as failed in UI
}

-- === Phase 3: PRODUCIR ===

rule Phase3_Producir {
  when: phase 3 is triggered for a VisualReasoning

  requires: VisualReasoning.phase2Status = completed
  requires: VisualReasoning.visualPrompt is present

  ensures: generation call dispatched to the function matching GlobalConfig.generationModel:
    -- Gemini models → api-gemini function; output: bitmap (PNG, 800×800px, base64)
    -- Recraft raster (recraftv4_1) → api-recraft function; output: bitmap (PNG, 800×800px, base64)
    -- Recraft vector (recraftv4_1_vector) → api-recraft function; output: native SVG string
    -- All calls use background function + polling pattern (see Phase3_BackgroundExecution)
    -- Pictograms are always square: Gemini imageConfig.aspectRatio "1:1",
    --   Recraft size "1024×1024" (or the model's square equivalent)
  ensures: on success with bitmap output:
    VisualReasoning.bitmap = base64 PNG at 800×800px
    VisualReasoning.rawSvg = nil        -- prior Phase 4 rawSvg cleared
    VisualReasoning.pictograma = nil    -- prior Phase 5 output cleared
    VisualReasoning.generationModel = GlobalConfig.generationModel at trigger time
    VisualReasoning.phase3Status = completed
    VisualReasoning.phase4Status = idle
    VisualReasoning.phase5Status = idle
  ensures: on success with vector output:
    VisualReasoning.rawSvg = native SVG content
    VisualReasoning.bitmap = nil        -- no bitmap produced by this model
    VisualReasoning.pictograma = nil    -- prior Phase 5 output cleared
    VisualReasoning.generationModel = GlobalConfig.generationModel at trigger time
    VisualReasoning.phase3Status = completed
    VisualReasoning.phase4Status = idle -- phase4 is not applicable for vector rows
    VisualReasoning.phase5Status = outdated  -- if previously completed
  ensures: on any generation error (timeout, malformed response, empty body):
    VisualReasoning.phase3Status = failed
}

rule Phase3_BackgroundExecution {
  -- Applies to Phase 3 for all generation models.
  -- Phase 3 is a long-running operation (2–30 s); it runs via background function
  -- and is polled until a result is available.

  when: phase3Status transitions to running

  ensures: elapsed time is tracked from this exact moment
  ensures: elapsed time is visible in the UI while phase3Status = running
    -- the timer must not wait for the row to be expanded, focused, or scrolled
    -- the timer is not reset by any UI interaction (collapse, row switch, navigation)
  ensures: a Stop action is available in the UI while phase3Status = running

  @invariant "timer origin is trigger time"
    -- The elapsed counter reflects wall-clock time since Phase 3 was triggered.
    -- It does not start over when the row is first rendered or expanded.
}

rule Phase3_Stop {
  when: user triggers Stop on a VisualReasoning while phase3Status = running

  ensures: the in-flight background job is cancelled (poll loop terminated)
  ensures: phase3Status transitions to idle
    -- idle, not failed: user-initiated stop is not an error
  ensures: any partial bitmap or rawSvg from the incomplete run is discarded
  ensures: VisualReasoning.generationModel is NOT updated
    -- provenance is set only on successful Phase 3 completion
}

rule Phase3_Failure {
  when: VisualReasoning.phase3Status transitions to failed

  ensures: full error detail logged to console (model id, raw error, elapsed time)
  ensures: phase 3 indicator shown as failed in UI
  -- User manually re-triggers phase 3 to retry.
}

-- === Phase 4: VECTORIZAR (user-triggered) ===

rule Phase4_Vectorizar {
  when: user triggers Vectorizar on a VisualReasoning

  requires: VisualReasoning.phase3Status = completed
  requires: VisualReasoning.bitmap is present
  requires: modelFamily(VisualReasoning.generationModel) = bitmap
    -- Phase 4 is never triggered for rows where generationModel = recraftv4_1_vector

  ensures: VTracer WASM runs locally on VisualReasoning.bitmap
    -- no API call; no quota charge; geometry stays in the browser
  ensures: on success:
    VisualReasoning.rawSvg = SVG string produced by VTracer
    VisualReasoning.phase4Status = completed
  ensures: on VTracer error:
    VisualReasoning.phase4Status = failed

  @invariant "user-triggered only"
    -- Phase 4 is never invoked automatically by the pipeline cascade.
    -- It runs only on explicit user action.

  @invariant "bitmap preserved after vectorization"
    -- Completing Phase 4 does not clear VisualReasoning.bitmap.
    -- The bitmap remains available after rawSvg is produced.
}

rule Phase4_Failure {
  when: VisualReasoning.phase4Status transitions to failed

  ensures: full error detail logged to console
  ensures: phase 4 indicator shown as failed in UI
  -- User can re-trigger Phase 4 to retry.
}

-- === Phase 5: ESTRUCTURAR ===

rule Phase5_Estructurar {
  when: phase 5 is triggered for a VisualReasoning

  requires: VisualReasoning.rawSvg is present
    -- rawSvg may come from Phase 4 (VTrace of a bitmap) or directly from
    -- Phase 3 (Recraft vector model). Phase 5 does not distinguish the source.
  requires: VisualReasoning.visualDom is present

  ensures: Phase5_SetOfMarks attempted, producing an [ElementMapping]
  ensures: Phase5_Validate runs on the mapping, triggering focused retries as needed
  ensures: Phase5_Assemble runs on the final mapping
  ensures: on successful assembly:
    VisualReasoning.pictograma = assembled SVG content
    VisualReasoning.phase5Status = completed
  ensures: on tool-use failure in all attempts:
    VisualReasoning.phase5Status = failed

  @invariant "always delivers on coverage or confidence issues"
    -- Low confidence and unmapped nodes are not failure conditions.
    -- Phase 5 only fails if Claude does not invoke the tool at all.
    -- After config.phase5_max_attempts, the best available mapping is used.
}

rule Phase5_SetOfMarks {
  when: phase 5 begins an attempt

  ensures: rawSvg parsed into indexed elements (paths and closed shapes)
    -- each element assigned a stable numeric index (0, 1, 2, ...)
    -- bounding box and centroid computed per element
  ensures: rawSvg rasterized to image
  ensures: numeric label overlaid at centroid of each element
    -- labels must be visually distinct and legible at the rendered resolution
  ensures: Claude Sonnet called with vision:
    -- image: marked rasterization
    -- context: VisualDOM from phase 2
    -- tool name: "map_elements"
    -- tool input_schema: [ElementMapping]
        where ElementMapping.nodeId is constrained to valid VisualDOMNode ids or "none"
    -- tool_choice: forced to "map_elements"
  ensures: on success: mapping returned as [ElementMapping] with confidence per assignment
}

rule Phase5_Validate {
  when: a mapping is produced by Phase5_SetOfMarks

  ensures: mapping inspected for:
    -- total coverage: every indexed element has exactly one assignment
    -- required node coverage: every required VisualDOMNode has at least
        one element assigned to it (nodeId = node.id)

  ensures: for each assignment with confidence below config.phase5_confidence_threshold:
    if current attempt < config.phase5_max_attempts:
      Phase5_FocusedRetry triggered for that element
    else:
      assignment retained as-is regardless of confidence
}

rule Phase5_FocusedRetry {
  when: an element assignment has low confidence AND attempts remain

  ensures: element rendered in isolation (tightly cropped rasterization)
  ensures: Claude Sonnet called again with isolated image and same VisualDOM
    -- only the ambiguous element is re-evaluated
  ensures: result replaces the original assignment for that element only
  ensures: attempt counter incremented
}

rule Phase5_Assemble {
  when: mapping is final (validated or max attempts reached)

  ensures: local code assembles the Pictograma SVG:
    -- elements grouped under their assigned VisualDOMNode ids as <g> elements
    -- elements assigned "none" placed in a fallback group
    -- path geometry (d attributes) sourced exclusively from rawSvg
    -- result conforms to mf-svg-schema document structure

  @invariant "geometry stays local"
    -- Claude provides only the mapping (index → nodeId).
    -- No path d attribute is read from or modified by Claude's response.

  @invariant "one element, one group"
    -- Each element appears in exactly one <g> in the assembled Pictograma,
    -- whether it is a named semantic group or the fallback group.
}

rule Phase5_Failure {
  when: VisualReasoning.phase5Status transitions to failed

  ensures: full error detail logged to console (attempt count, last raw response)
  ensures: phase 5 indicator shown as failed in UI
  -- User can re-trigger phase 5 to start a fresh set of attempts.
}

------------------------------------------------------------
-- Invariants
------------------------------------------------------------

invariant DownstreamConsistency {
  -- A phase's outdated status propagates forward without gaps.
  for r: VisualReasoning:
    r.phase1Status = outdated →
      r.phase2Status in {outdated, idle}
      r.phase3Status in {outdated, idle}
      r.phase4Status in {outdated, idle}
      r.phase5Status in {outdated, idle}
    r.phase2Status = outdated →
      r.phase3Status in {outdated, idle}
      r.phase4Status in {outdated, idle}
      r.phase5Status in {outdated, idle}
    r.phase3Status = outdated →
      r.phase4Status in {outdated, idle}
      r.phase5Status in {outdated, idle}
    r.phase4Status = outdated →
      r.phase5Status in {outdated, idle}
}

invariant GeometryIntegrity {
  -- Path geometry in the Pictograma is identical to rawSvg.
  -- Phase 5 only rearranges paths into groups; it does not alter geometry.
  for r: VisualReasoning where r.phase5Status = completed:
    for path in paths(r.pictograma):
      path.d = getPath(r.rawSvg, path.id).d
}

invariant NativeSVGOnly {
  -- rawSvg always contains real vector paths, never an embedded raster.
  -- This applies whether rawSvg came from Phase 3 (vector model) or Phase 4 (VTrace).
  for r: VisualReasoning where r.rawSvg is present:
    r.rawSvg does not contain <image> elements
}

invariant BitmapSquare {
  -- All bitmaps stored in VisualReasoning.bitmap are 800×800px.
  for r: VisualReasoning where r.bitmap is present:
    dimensions(r.bitmap) = 800 × 800
}

invariant Phase4NeverAutoRuns {
  -- Phase 4 transitions to running only via explicit user action,
  -- never as a consequence of Phase 3 completing.
  phase4Status transitions to running
    only when user explicitly triggers Vectorizar
}

------------------------------------------------------------
-- Open Questions
------------------------------------------------------------

open question "Does processCascade run phases 1–3 automatically after utterance confirmation, with phases 4 and 5 remaining user-initiated? Or does the user trigger each phase manually?"

open question "When a required VisualDOMNode has zero elements assigned after max attempts, does the Pictograma contain an empty <g id=node.id> or is the node omitted entirely?"

open question "What render resolution is used for the set-of-marks image? It must be high enough to distinguish small elements without exceeding API image size limits."

open question "Is config.phase5_confidence_threshold the right abstraction, or does the model's justification string need human review to determine retry worthiness?"

open question "Should VisualDOM validation against mf-svg-schema happen in phase 2 (before phase3Status can proceed) or lazily at the start of phase 5?"
