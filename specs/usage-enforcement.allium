-- allium: 3
-- usage-enforcement.allium

-- Scope: Per-user daily quota enforcement and audit logging for all AI API calls.
-- Covers: quota model, Netlify Blobs schema, enforcement flow per function,
--   admin report endpoint, dev bypass, 429 contract, Gemini key selection.
-- Excludes:
--   - Pipeline phase logic (see visual-reasoning.allium)
--   - Generation model selection and library config (see generation-config.allium)
--   - Netlify Identity JWT validation (enforced by each function independently)
--   - UI feedback for quota exhaustion (separate spec)
-- Dependencies: Netlify Identity (user.email), Netlify Blobs (pictonet-usage store)

------------------------------------------------------------
-- Value Types
------------------------------------------------------------

value QuotaRecord {
  -- Stored in Blobs at quota/{email}/{date}.
  units: Number           -- cumulative units charged today
  first_call: Timestamp?
  last_call: Timestamp
}

value AuditRecord {
  -- One blob per call at audit/{date}/{timestamp-safeEmail}.
  -- Keyed by timestamp to avoid write contention.
  ts: Timestamp
  email: String
  phase: String           -- "claude" | "recraft" | "gemini"
  model: String           -- e.g. "claude-haiku-4-5-20251001", "recraftv4_1_vector", "gemini-2.5-flash-image"
  units_charged: Number   -- 0 or 1
  ms: Number              -- wall-clock milliseconds for the upstream call
  tokens_in: Number       -- 0 for Recraft (no token concept)
  tokens_out: Number
  ok: Boolean
  error_msg: String?      -- present only when ok = false
}

value QuotaCheckResult {
  allowed: Boolean
  units_used: Number      -- updated total after charging (if allowed)
  limit: Number
}

------------------------------------------------------------
-- Config
------------------------------------------------------------

config {
  daily_limit: Number = 50          -- overridable via DAILY_LIMIT_PER_USER env var
  blob_store: String = "pictonet-usage"
  admin_email: String = "contact@pictos.net"
}

------------------------------------------------------------
-- Quota Model
------------------------------------------------------------

-- The "unit" is the pictogram-level cost atom.
-- One image generation call (any model) = one completed pictogram attempt = 1 unit.
-- All api-claude calls = 0 units (phases 1, 2, and 5 are not counted).
-- Quota tracks pictogram generation attempts, not AI token consumption.

rule QuotaUnitsPerCall {
  for each incoming request to a proxied function:

  if function = api-recraft OR function = api-gemini:
    units_to_charge = 1
    -- flat rate: Gemini Flash, Gemini Pro, Recraft raster, Recraft vector
    -- all charge 1 unit regardless of model

  if function = api-claude:
    units_to_charge = 0      -- haiku (phases 1+2) and sonnet (phase 5) both free

  if email = "dev" (local dev bypass) OR units_to_charge = 0:
    quota check skipped entirely — request always allowed

  @invariant "claude never blocked by quota"
    -- No api-claude call (any model, any phase) is ever blocked by quota.
    -- Only image generation calls (api-recraft, api-gemini) consume quota units.

  @invariant "flat rate across generation models"
    -- The unit cost does not vary by model within api-recraft or api-gemini.
    -- Gemini Pro and Gemini Flash both cost 1 unit.

  @invariant "dev bypass applies to local only"
    -- NETLIFY_DEV is not set in deployed Netlify environments.
    -- The 'dev' email path is unreachable in production or preview deployments.
}

------------------------------------------------------------
-- Blob Schema
------------------------------------------------------------

-- Store: "pictonet-usage"
--
-- quota/{email}/{YYYY-MM-DD}
--   type: QuotaRecord (JSON)
--   semantics: mutable; read-modify-write on each charged call
--   race condition: possible under concurrent requests; acceptable at current scale
--
-- audit/{YYYY-MM-DD}/{HH-MM-SS-mmm}-{safeEmail}
--   type: AuditRecord (JSON)
--   semantics: write-once; timestamp key guarantees uniqueness per call
--   race condition: none (unique key per invocation)

rule BlobKeyFormat {
  ensures: quota key = "quota/" + email + "/" + YYYY-MM-DD
  ensures: audit key = "audit/" + YYYY-MM-DD + "/" + HH-MM-SS-mmm + "-" + safeEmail
    where safeEmail = email with non-[a-zA-Z0-9@._-] replaced by "_", max 80 chars
  ensures: audit blob written after every API call, regardless of outcome
    -- ok=false entries are still written; they are the primary abuse signal
}

------------------------------------------------------------
-- Enforcement Rules
------------------------------------------------------------

rule EnforceQuotaBefore {
  when: an api-claude or api-recraft function receives a POST request

  requires: user authenticated (Netlify Identity JWT valid OR isLocalDev = true)

  ensures:
    1. email extracted from context.clientContext.user?.email ?? "dev"
    2. if units_to_charge > 0:
         QuotaRecord read from Blobs (missing = { units: 0 })
         if QuotaRecord.units >= config.daily_limit:
           return HTTP 429 { error, units_used, limit }
         else:
           QuotaRecord.units incremented and written back
    3. upstream API call proceeds only after quota check passes

  @invariant "check before call"
    -- The upstream API (Anthropic / Recraft) is never called if quota is exhausted.
    -- HTTP 429 is returned before any external cost is incurred.
}

rule LogAfterCall {
  when: the upstream API call completes (success or failure)

  ensures: AuditRecord written to Blobs with ok=true or ok=false
  ensures: AuditRecord write is non-blocking
    -- a Blobs write failure must not cause the function to return an error
    -- the failure is logged to console and silently discarded
  ensures: AuditRecord written even if the upstream call errored

  @invariant "audit never blocks response"
    -- logCall() runs after the response body is prepared.
    -- Its failure path does not alter the HTTP response code or body.
}

rule DevBypass {
  when: process.env.NETLIFY_DEV = "true" AND no user in clientContext

  ensures: JWT validation skipped
  ensures: email = "dev"
  ensures: quota check skipped (dev is always allowed)
  ensures: audit logging skipped (dev calls produce no Blob entries)
}

------------------------------------------------------------
-- Gemini Key Selection
------------------------------------------------------------

rule GeminiKeySelection {
  -- api-gemini uses different API keys for local dev and deployed environments.
  -- Both keys are server-side only; neither reaches the browser.

  when: api-gemini function handles a request

  ensures: API key selected as:
    if NETLIFY_DEV = "true": use GEMINI_LOCAL_API_KEY
    else: use GEMINI_PUBLIC_API_KEY

  @deployment "key restriction requirement"
    -- GEMINI_PUBLIC_API_KEY must be restricted by API restriction
    --   (Generative Language API only), NOT by HTTP referrer.
    -- HTTP referrer restrictions are enforced by the browser; server-side
    --   Netlify functions send no browser referrer, so a referrer-restricted
    --   key will be rejected by Google's API with a 403.
    -- If the key is currently referrer-restricted (e.g. to pictos.net and
    --   next.pictos.net), switch it to API restriction in the Google Cloud
    --   console before deploying api-gemini to production.
    -- GEMINI_LOCAL_API_KEY is unrestricted or restricted to local use only;
    --   it must never be deployed to production or preview environments.
}

------------------------------------------------------------
-- Admin Report
------------------------------------------------------------

entity UsageReport {
  -- Returned by api-usage-report on a successful GET.
  date: String          -- YYYY-MM-DD
  total_calls: Number   -- sum of all AuditRecord entries for the date
  total_units: Number   -- sum of units_charged across all entries
  users: Map<String, UserSummary>
}

value UserSummary {
  calls: Number
  units: Number
  phases: Map<String, Number>   -- phase → call count
  errors: Number                -- count of ok=false entries
}

rule AdminReportEndpoint {
  -- GET /.netlify/functions/api-usage-report?date=YYYY-MM-DD

  when: GET request received

  requires: user authenticated
  requires: user.email = config.admin_email
    -- HTTP 403 returned for any other authenticated user

  ensures: all audit/{date}/ blobs read and aggregated into UsageReport
  ensures: HTTP 200 with UsageReport JSON body
  ensures: date defaults to today if query param absent
  ensures: HTTP 400 if date does not match /^\d{4}-\d{2}-\d{2}$/

  @invariant "admin-only"
    -- No non-admin user, even authenticated, can access usage data via this endpoint.
    -- Owner email is hardcoded in config.admin_email; not derived from env or JWT claims.
}

------------------------------------------------------------
-- HTTP Contract
------------------------------------------------------------

rule HTTP429Contract {
  when: quota exhausted for a user

  ensures: HTTP 429 response
  ensures: body = { error: "Daily quota exceeded", units_used: Number, limit: Number }
  ensures: upstream API not called
  ensures: no AuditRecord written for the blocked request
    -- a blocked request is not a call; it is not billable and not auditable

  @invariant "429 is the only quota response code"
    -- Quota exhaustion never returns 200, 400, or 500.
    -- Callers can distinguish quota exhaustion from other errors by status code alone.
}

------------------------------------------------------------
-- Invariants
------------------------------------------------------------

invariant AuditCompleteness {
  -- Every request that reaches the upstream API has a corresponding AuditRecord.
  for each upstream API call:
    exists AuditRecord where AuditRecord.ts is within 5s of call completion
}

invariant QuotaMonotonicity {
  -- A user's daily unit count never decreases within a calendar day.
  -- (Absent manual admin intervention on Blobs.)
  for each QuotaRecord:
    QuotaRecord.units is non-decreasing across successive reads on the same date
}

invariant AdminAccessControl {
  -- api-usage-report returns 200 only for config.admin_email.
  -- All other callers receive 401 (unauthenticated) or 403 (authenticated, not admin).
}

------------------------------------------------------------
-- Open Questions
------------------------------------------------------------

open question "Should audit blobs have an explicit TTL or cleanup policy? Currently they accumulate indefinitely."

open question "When concurrent requests from the same user race on the quota counter, should the overflow be corrected retroactively or is best-effort sufficient?"

open question "Should the 429 response include a Retry-After header indicating when the quota resets (midnight UTC)?"

open question "Should quota limits be per-site (prod vs. preview) or shared across both deployments for the same user?"
